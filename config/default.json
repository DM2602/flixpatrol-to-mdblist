    },
    {
      "platform": "disney",
      "location": "world",
      "fallback": false,
      "limit": 10,
      "type": "both",
      "name": "Disney Plus Top 10",
      "normalizeName": true
    },
    {
      "platform": "amazon-prime",
      "location": "world",
      "fallback": false,
      "limit": 10,
