# ┌────────────────────────────────────────────────────────────┐
# │  FlixPatrol → MDBList  –  Environment Configuration       │
# │  Copy to .env and fill in your values.                    │
# └────────────────────────────────────────────────────────────┘

# Required: your MDBList API key
# Get it free at https://mdblist.com/preferences/
MDBLIST_API_KEY=

# Cron schedule (5-field cron expression)
# Default: twice daily at 06:00 and 18:00
# FlixPatrol only updates once per day – running more often wastes API calls.
#
# Examples:
#   0 6 * * *        → daily at 06:00
#   0 6,18 * * *     → twice daily (recommended)
#   0 */12 * * *     → every 12 hours
#   0 3 * * 1        → Mondays at 03:00
#   @daily           → midnight
#
# ⚠ Do NOT use "* * * * *" (every minute) – this hammers FlixPatrol
#   and burns your MDBList API quota (free = 1000/day).
SCHEDULE=0 6,18 * * *

# Timezone for the scheduler
TZ=Europe/Zurich

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Dry run – logs what would happen without touching MDBList
DRY_RUN=false

# Run once and exit (useful for testing or external cron)
RUN_ONCE=false
